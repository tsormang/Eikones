<UserControl x:Class="Eikones.Views.PreviewColumnView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Eikones.Converters">
    <UserControl.Resources>
        <converters:NullToOpacityConverter x:Key="NullToOpacityConverter"/>
    </UserControl.Resources>

    <Grid Background="#1E1E1E">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Viewbox Stretch="Uniform"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center">
                <Image Source="{Binding Preview.PlaceholderSource}"
                       Stretch="None"
                       RenderOptions.BitmapScalingMode="LowQuality">
                    <Image.Effect>
                        <BlurEffect Radius="12" KernelType="Gaussian"/>
                    </Image.Effect>
                </Image>
            </Viewbox>

            <Viewbox Stretch="Uniform"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center">
                <Image Source="{Binding Preview.FullPreviewSource}"
                       Stretch="None"
                       RenderOptions.BitmapScalingMode="HighQuality">
                    <Image.Style>
                        <Style TargetType="Image">
                            <Setter Property="Opacity" Value="1"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Preview.FullPreviewSource}" Value="{x:Null}">
                                    <Setter Property="Opacity" Value="0"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Image.Style>
                </Image>
            </Viewbox>

            <TextBlock HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="#888888"
                       FontSize="16"
                       Text="Select an image to preview"
                       Visibility="{Binding Preview.CurrentImage, Converter={StaticResource NullToVisibilityConverter}}"/>
        </Grid>

        <ProgressBar Grid.Row="0"
                     Height="4"
                     VerticalAlignment="Bottom"
                     IsIndeterminate="True"
                     Visibility="{Binding Preview.IsLoadingFullPreview, Converter={StaticResource BooleanToVisibilityConverter}}"/>

        <Border Grid.Row="1" Background="#2A2A2A" Padding="12,8">
            <StackPanel>
                <TextBlock Foreground="White"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Text="{Binding Preview.CurrentImage.FileName, FallbackValue=No image selected}"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Foreground="#AAAAAA"
                           FontSize="11"
                           Margin="0,4,0,0"
                           Text="{Binding Preview.DateTakenDisplay, FallbackValue=Date taken: unavailable}"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,8,0,12">
            <Button Content="Delete (Del)"
                    Margin="6,0"
                    Padding="16,8"
                    Command="{Binding Preview.DeleteCommand}"/>
            <Button Content="Delete all Previous (Shift+Del)"
                    Margin="6,0"
                    Padding="16,8"
                    Command="{Binding DeleteAllPreviousCommand}"/>
            <Button Content="Move (Enter)"
                    Margin="6,0"
                    Padding="16,8"
                    Command="{Binding Preview.MoveCommand}"/>
        </StackPanel>
    </Grid>
</UserControl>
