<UserControl x:Class="Eikones.Views.SourceColumnView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Eikones.ViewModels"
             Focusable="True"
             AllowDrop="True"
             DragOver="SourceColumn_OnDragOver"
             Drop="SourceColumn_OnDrop">
    <Border BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Margin="8,8,8,4"
                       FontSize="11"
                       Foreground="#666666"
                       Text="{Binding SourceBrowser.StatusMessage}"
                       TextTrimming="CharacterEllipsis"/>

            <ListBox x:Name="SourceList"
                     Grid.Row="1"
                     ItemsSource="{Binding SourceBrowser.Images}"
                     SelectedItem="{Binding SelectedImage, Mode=TwoWay}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     VirtualizingPanel.CacheLengthUnit="Page"
                     VirtualizingPanel.CacheLength="1,1"
                     SelectionChanged="SourceList_OnSelectionChanged">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <EventSetter Event="Loaded" Handler="SourceItem_OnLoaded"/>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:ImageItemViewModel}">
                        <Grid Width="90" Height="110" Margin="4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="90"/>
                                <RowDefinition Height="20"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#F3F3F3">
                                <Image Source="{Binding ThumbnailSource}"
                                       Stretch="UniformToFill"
                                       RenderOptions.BitmapScalingMode="LowQuality"/>
                            </Border>
                            <TextBlock Grid.Row="1"
                                       Text="{Binding FileName}"
                                       FontSize="10"
                                       TextTrimming="CharacterEllipsis"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <TextBlock Grid.Row="1"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="#999999"
                       Text="No images in source folder"
                       Visibility="{Binding SourceBrowser.Images.Count, Converter={StaticResource ZeroToVisibilityConverter}}"/>
        </Grid>
    </Border>
</UserControl>
