<Window x:Class="Eikones.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Eikones.Views"
        Title="{Binding WindowTitle}"
        Height="{Binding WindowHeight}"
        Width="{Binding WindowWidth}"
        MinHeight="500"
        MinWidth="900"
        Loaded="MainWindow_OnLoaded"
        Closing="MainWindow_OnClosing"
        PreviewKeyDown="MainWindow_OnKeyDown">
    <DockPanel>
        <ToolBar DockPanel.Dock="Top" Background="#F5F5F5">
            <Button Content="Settings"
                    Padding="12,4"
                    Command="{Binding OpenSettingsCommand}"
                    ToolTip="Open settings (Ctrl+,)"/>
        </ToolBar>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="180" MaxWidth="320"/>
                <ColumnDefinition Width="5*"/>
                <ColumnDefinition Width="220" MinWidth="180" MaxWidth="320"/>
            </Grid.ColumnDefinitions>

            <views:SourceColumnView Grid.Column="0"/>
            <views:PreviewColumnView Grid.Column="1"/>
            <views:DestinationColumnView Grid.Column="2"/>
        </Grid>
    </DockPanel>

    <Window.InputBindings>
        <KeyBinding Key="Delete" Command="{Binding Preview.DeleteCommand}"/>
        <KeyBinding Key="Delete" Modifiers="Shift" Command="{Binding DeleteAllPreviousCommand}"/>
        <KeyBinding Key="Enter" Command="{Binding Preview.MoveCommand}"/>
        <KeyBinding Key="M" Command="{Binding Preview.MoveCommand}"/>
        <KeyBinding Key="O" Modifiers="Ctrl" Command="{Binding OpenSettingsCommand}"/>
        <KeyBinding Key="OemComma" Modifiers="Ctrl" Command="{Binding OpenSettingsCommand}"/>
    </Window.InputBindings>
</Window>
